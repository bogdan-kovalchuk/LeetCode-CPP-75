{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "LeetCode: build active file (LOCAL_TEST)",
            "type": "process",
            "command": "powershell",
            "args": [
                "-NoProfile",
                "-ExecutionPolicy",
                "Bypass",
                "-File",
                "${workspaceFolder}\\.vscode\\run-leetcode-task.ps1",
                "-SourceFile",
                "${file}"
            ],
            "problemMatcher": [
                "$msCompile"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            }
        },
        {
            "label": "LeetCode: run active file tests (LOCAL_TEST)",
            "type": "process",
            "command": "powershell",
            "args": [
                "-NoProfile",
                "-ExecutionPolicy",
                "Bypass",
                "-File",
                "${workspaceFolder}\\.vscode\\run-leetcode-task.ps1",
                "-SourceFile",
                "${file}",
                "-Run"
            ],
            "problemMatcher": [
                "$msCompile"
            ]
        },
        {
            "label": "LeetCode: build all files (LOCAL_TEST)",
            "type": "process",
            "command": "powershell",
            "args": [
                "-NoProfile",
                "-ExecutionPolicy",
                "Bypass",
                "-File",
                "${workspaceFolder}\\.vscode\\run-leetcode-task.ps1",
                "-BuildAll"
            ],
            "problemMatcher": [
                "$msCompile"
            ]
        }
    ]
}
